# Copy client ID and secret from travel-app/.env.local (same Google Cloud project is fine)
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
# Get this by running: npm run oauth-setup
GMAIL_REFRESH_TOKEN=
NEWSLETTER_LABEL=Newsletters
# Production Gmail reconnect flow. Add this exact URI to the Google OAuth client's
# Authorized redirect URIs for production.
GMAIL_OAUTH_REDIRECT_URI=https://zo-bot.com/newsletter/api/gmail/oauth/callback
# Optional comma-separated Cloudflare Access emails allowed to reconnect Gmail.
GMAIL_OAUTH_ALLOWED_EMAILS=
# Optional: minutes between background auto-syncs (default 360; 0 disables).
SYNC_INTERVAL_MINUTES=360
# Shared secret so the homepage dashboard can read /api/summary over localhost.
# Must match INTERNAL_API_TOKEN in the homepage .env.
INTERNAL_API_TOKEN=
# Optional comma-separated Cloudflare Access emails with write access.
# Empty/unset means all authenticated users can write.
ADMIN_EMAILS=chrissdyer@gmail.com